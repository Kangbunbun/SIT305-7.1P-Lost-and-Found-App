<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="#EEEEEE"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imgItemThumbnail"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#CCCCCC"
        android:contentDescription="Item Image"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lost: Item description"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtItemCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category: Electronics" />

        <TextView
            android:id="@+id/txtItemDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date time" />

        <TextView
            android:id="@+id/txtItemLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="At location" />

    </LinearLayout>

</LinearLayout>